{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!biome-report.json",
			"!dist",
			"!frontend/dist",
			"!**/generated",
			"!**/*.min.js"
		]
	},
  "formatter": {
    "enabled": false
  },
	"linter": {
		"enabled": true,
		"includes": [
			"**",
			"!frontend/src/styles.css"
		],
		"rules": {
			"recommended": true
		}
	},
  "assist": {
    "enabled": false
  },
	"html": {
		"experimentalFullSupportEnabled": true
	}
}
